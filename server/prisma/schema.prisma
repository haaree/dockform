generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  type      String   @default("Standalone")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  plants Plant[]
  users  User[]
  forms  Form[]
  trades Trade[]

  @@map("companies")
}

model Plant {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  name            String
  code            String   @unique
  location        String?
  capacityWorkers Int?     @map("capacity_workers")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  users       User[]
  responses   Response[]

  @@map("plants")
}

model Department {
  id         String   @id @default(uuid()) @db.Uuid
  plantId    String   @map("plant_id") @db.Uuid
  name       String
  headUserId String?  @map("head_user_id") @db.Uuid
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")

  plant Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  head  User?  @relation("DepartmentHead", fields: [headUserId], references: [id])
  teams Team[]
  users User[]

  @@map("departments")
}

model Team {
  id           String   @id @default(uuid()) @db.Uuid
  departmentId String   @map("department_id") @db.Uuid
  name         String
  leadUserId   String?  @map("lead_user_id") @db.Uuid
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lead       User?      @relation("TeamLead", fields: [leadUserId], references: [id])
  users      User[]

  @@map("teams")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        String  @id @default(uuid()) @db.Uuid
  roleId    String  @map("role_id") @db.Uuid
  module    String
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("permissions")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  passwordHash        String?   @map("password_hash")
  fullName            String    @map("full_name")
  roleId              String?   @map("role_id") @db.Uuid
  companyId           String?   @map("company_id") @db.Uuid
  plantId             String?   @map("plant_id") @db.Uuid
  departmentId        String?   @map("department_id") @db.Uuid
  teamId              String?   @map("team_id") @db.Uuid
  status              String    @default("active")
  preferences         Json      @default("{}")
  // Real-time maintenance-team availability, driven by the work-permit auto-assignment flow
  // rather than a manual toggle: submitting a permit that matches this user's trade flips
  // them to "assigned" and stamps lastAssignedAt; the permit being marked complete/approved
  // flips them back to "free". "off_shift" is a manual override (e.g. on leave) that excludes
  // them from auto-assignment regardless of trade match.
  availabilityStatus  String    @default("free") @map("availability_status")
  lastAssignedAt      DateTime? @map("last_assigned_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  role       Role?       @relation(fields: [roleId], references: [id])
  company    Company?    @relation(fields: [companyId], references: [id])
  plant      Plant?      @relation(fields: [plantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  team       Team?       @relation(fields: [teamId], references: [id])

  departmentsHeaded Department[]      @relation("DepartmentHead")
  teamsLed          Team[]            @relation("TeamLead")
  formsCreated      Form[]
  responses             Response[]        @relation("ResponseSubmitter")
  assignedResponses     Response[]        @relation("ResponseAssignee")
  autoAssignedResponses Response[]        @relation("ResponseAutoAssignee")
  responseComments      ResponseComment[]
  trades                UserTrade[]

  @@map("users")
}

// A maintenance skill/trade (Electrician, Plumber, Mechanic, Civil Engineer, Supervisor, ...).
// Company-scoped so each company can define its own trade list rather than sharing a global one.
model Trade {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   UserTrade[]

  @@unique([companyId, name])
  @@map("trades")
}

// Many-to-many: a person can hold multiple trades (e.g. electrician + mechanic on a small team).
model UserTrade {
  userId  String @map("user_id") @db.Uuid
  tradeId String @map("trade_id") @db.Uuid

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@id([userId, tradeId])
  @@map("user_trades")
}

model Form {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  description      String?
  domain           String?
  tag              String?
  isTemplate       Boolean  @default(false) @map("is_template")
  isCustomTemplate Boolean  @default(false) @map("is_custom_template")
  status           String   @default("draft")
  createdById      String?  @map("created_by") @db.Uuid
  companyId        String?  @map("company_id") @db.Uuid
  assignedUserIds  Json?    @map("assigned_user_ids")
  scheduleMeta     Json?    @map("schedule_meta")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  createdBy User?       @relation(fields: [createdById], references: [id])
  company   Company?    @relation(fields: [companyId], references: [id])
  fields    FormField[]
  responses Response[]

  @@map("forms")
}

model FormField {
  id           String   @id @default(uuid()) @db.Uuid
  formId       String   @map("form_id") @db.Uuid
  sortOrder    Int      @default(0) @map("sort_order")
  type         String
  label        String
  placeholder  String   @default("")
  helpText     String   @default("") @map("help_text")
  defaultValue String   @default("") @map("default_value")
  options      Json     @default("[]")
  validation   Json     @default("{}")
  isRequired   Boolean  @default(false) @map("is_required")
  isReadOnly   Boolean  @default(false) @map("is_read_only")
  isHidden     Boolean  @default(false) @map("is_hidden")
  isSearchable Boolean  @default(false) @map("is_searchable")
  isIndexed    Boolean  @default(false) @map("is_indexed")
  logic        Json     @default("[]")
  // See FormField.isTradeSelector on the client -- marks this dropdown as the trade-matching
  // field for work-permit auto-assignment.
  isTradeSelector Boolean @default(false) @map("is_trade_selector")
  createdAt    DateTime @default(now()) @map("created_at")

  form            Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  responseValues  ResponseValue[]
  responseComments ResponseComment[]

  @@index([formId])
  @@map("form_fields")
}

model Response {
  id           String   @id @default(uuid()) @db.Uuid
  formId       String   @map("form_id") @db.Uuid
  submittedBy  String?  @map("submitted_by") @db.Uuid
  assignedToId String?  @map("assigned_to_id") @db.Uuid
  // The maintenance-team member auto-assigned by trade/availability (see
  // lib/workPermitAssignment.ts) -- deliberately a separate column from assignedToId, which is
  // the approval-routing target (the manager reviewing this submission). A work-permit
  // response needs both at once: a manager to approve it AND a worker doing the job: they are
  // never the same person and must never share a column, or auto-assignment would silently
  // overwrite/impersonate the approver.
  autoAssignedUserId String?  @map("auto_assigned_user_id") @db.Uuid
  plantId      String?  @map("plant_id") @db.Uuid
  status       String   @default("draft")
  submittedAt  DateTime @default(now()) @map("submitted_at")

  form           Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  user           User?             @relation("ResponseSubmitter", fields: [submittedBy], references: [id])
  assignedTo     User?             @relation("ResponseAssignee", fields: [assignedToId], references: [id])
  autoAssignedTo User?             @relation("ResponseAutoAssignee", fields: [autoAssignedUserId], references: [id])
  plant          Plant?            @relation(fields: [plantId], references: [id])
  values      ResponseValue[]
  comments    ResponseComment[]
  annotations ResponseAnnotation[]

  @@map("responses")
}

// A manager's review note on a Send for Approval response -- either an overall comment
// (fieldId null) or a per-field one. instanceId additionally scopes a comment to one
// entry of a repeatable section (the stable SectionInstance.id from the client, not an
// array index), since a repeatable field's fieldId alone can't distinguish "Area 2's
// reading" from "Area 5's". resolved is set true once the submitter's next resubmit
// addresses it, so the resubmit-lock logic knows which fields are still open.
model ResponseComment {
  id         String   @id @default(uuid()) @db.Uuid
  responseId String   @map("response_id") @db.Uuid
  fieldId    String?  @map("field_id") @db.Uuid
  instanceId String?  @map("instance_id")
  text       String
  authorId   String?  @map("author_id") @db.Uuid
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  field    FormField? @relation(fields: [fieldId], references: [id])
  author   User?      @relation(fields: [authorId], references: [id])

  @@index([responseId])
  @@map("response_comments")
}

model ResponseValue {
  id         String @id @default(uuid()) @db.Uuid
  responseId String @map("response_id") @db.Uuid
  fieldId    String @map("field_id") @db.Uuid
  value      Json   @default("null")

  response    Response             @relation(fields: [responseId], references: [id], onDelete: Cascade)
  field       FormField            @relation(fields: [fieldId], references: [id])
  attachments ResponseAttachment[]

  @@unique([responseId, fieldId])
  @@index([responseId])
  @@map("response_values")
}

// A filler's own note/photo attached to a top-level field while answering it (see the
// client's lib/fieldAnnotations.ts noteKey/mediaKey convention) -- distinct from
// ResponseComment, which is a manager's review note. Stored in its own table rather than
// as a ResponseValue row because that column's fieldId is a real UUID FK to FormField;
// the sidecar keys the client sends (`${fieldId}__note`, `${fieldId}__media`) aren't valid
// field UUIDs and would violate that constraint. kind distinguishes note vs media so both
// can coexist per field without a compound key collision. Annotations on repeatable-section
// fields are unaffected -- those already live inside the section's own JSON blob and never
// reach this table.
model ResponseAnnotation {
  id         String   @id @default(uuid()) @db.Uuid
  responseId String   @map("response_id") @db.Uuid
  fieldId    String   @map("field_id")
  kind       String
  value      String

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([responseId, fieldId, kind])
  @@index([responseId])
  @@map("response_annotations")
}

model ResponseAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  responseValueId String   @map("response_value_id") @db.Uuid
  storageKey      String   @map("storage_key")
  mimeType        String?  @map("mime_type")
  sizeBytes       BigInt?  @map("size_bytes")
  createdAt       DateTime @default(now()) @map("created_at")

  responseValue ResponseValue @relation(fields: [responseValueId], references: [id], onDelete: Cascade)

  @@map("response_attachments")
}
